------------------------------------------------------------1.TYPES OF DESCRIPTIONS/MODELING STYLES IN VERILOG-------------------------------------------------------------.

                                                                        1.BEHAVIORAL DESCRIPTION---->(HIGHER-LEVEL)---->C LANGUAGE {IF..ELSE,LOOP,OTHER FUN}
                                                                        2.DATAFLOW DESCRIPTION------>CONTINUES ASSIGNMENT
                                                                        3.GATE LEVEL DESCRIPTION---->BASIC GATES & UNIVERSAL GATES
                                                                        4.SWITCH LEVEL DESCRIPTION---->(LOWEST-LEVEL)--->CMOS TRANSISTORS


------------------------------------------------------------2.DESIGN OF 2:1 MUX--------------------------------------------------------------------------------------------

--------------------------------------1.DATAFLOW_MODEL----------------------------------

module mux_2_1(input a,b,sel,
              output y);
  
  assign y=(~sel&a)|(sel&b);
  
endmodule

------------------------------------2.GATELEVEL_MODELING--------------------------------


module mux_2_1(input a,b,sel,
              output y);
  wire w1,w2;
 
  and g1(w1,~sel,a);
  and g2(w2,sel,b);
  or g3(y,w1,w2);
  end
endmodule

-----------------------------------3.behavioral modeling-------------------------------



module mux_2_1(input a,b,sel,
              output reg y);
  
  always@(*)
    begin
      if(sel==0)
                y=a;
      else
       		 y=b;
    end
  
endmodule
-----------------------------------------------------------------------TEST_BENCH_FOR_THE_2:1_MUX--------------------------------------------------------------------------


module mux_2_1_tb();
  
  reg a,b,sel;
  wire y;
  
  
  mux_2_1 DUT(
    .a(a),
    .b(b),
    .sel(sel),
    .y(y)
  );
  
  initial begin
    $dumpfile("start.vcd");
    $dumpvars(0,mux_2_1_tb);


       
    $monitor("|time=%0t| a=%b | b=%b | sel=%b | y=%b | ",$time,a,b,sel,y);
    $display("-----------------------------------------");
      
     a=0; b=0; sel=0;
    #10; a=0; b=1; sel=0;
    #10; a=1; b=0; sel=0;
    #10; a=1; b=1; sel=0;
      
  
      
       
    
    #10; a=0; b=0; sel=1;
